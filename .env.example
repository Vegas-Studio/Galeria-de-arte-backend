# Base de datos PostgreSQL
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=24h

# Servidor
PORT=3000

# CORS — orígenes permitidos separados por coma (sin barra final)
# Ejemplo Netlify: https://tu-app.netlify.app
CORS_ORIGINS=https://tu-app.netlify.app
# URL principal del frontend (usada en enlaces de recuperación de contraseña)
FRONTEND_URL=https://tu-app.netlify.app
# Permitir cualquier subdominio *.netlify.app (true por defecto)
CORS_ALLOW_NETLIFY=true

# SMTP (Nodemailer) — recuperación de contraseña
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM="Obsidian Gallery <noreply@tu-dominio.com>"
